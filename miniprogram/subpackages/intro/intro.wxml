<view class="intro-container">
  <view class="image-list">
    <view 
      class="image-item" 
      wx:for="{{introImages}}" 
      wx:key="*this"
    >
      <image 
        class="intro-image" 
        src="{{item}}" 
        mode="widthFix"
        data-index="{{index}}"
        bindtap="onImageTap"
      ></image>
    </view>
  </view>

  <view 
    class="preview-mask {{previewVisible ? 'show' : ''}}" 
    bindtap="onMaskTap"
  >
    <image 
      class="preview-image" 
      src="{{introImages[currentIndex]}}" 
      mode="aspectFit"
      style="transform: scale({{scale}}) translateX({{translateX}}px);"
      bindtap="onImageTapInner"
      bindtouchstart="onTouchStart"
      bindtouchmove="onTouchMove"
      bindtouchend="onTouchEnd"
    ></image>
    <view class="preview-counter">{{currentIndex + 1}} / {{introImages.length}}</view>
    <view class="preview-close" bindtap="closePreview">×</view>
    <view class="preview-tips">双指缩放 | 左右滑动切换 | 点击关闭</view>
  </view>
</view>
