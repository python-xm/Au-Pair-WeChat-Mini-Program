.intro-container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.image-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.image-item {
  width: 100%;
  background-color: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.intro-image {
  width: 100%;
  display: block;
}

.preview-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.95);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.3s, visibility 0.3s;
}

.preview-mask.show {
  opacity: 1;
  visibility: visible;
}

.preview-image {
  width: 100%;
  height: 100%;
  transition: transform 0.1s;
}

.preview-counter {
  position: absolute;
  top: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  color: #ffffff;
  font-size: 28rpx;
  background-color: rgba(0, 0, 0, 0.5);
  padding: 10rpx 30rpx;
  border-radius: 30rpx;
}

.preview-close {
  position: absolute;
  top: 30rpx;
  right: 30rpx;
  width: 60rpx;
  height: 60rpx;
  line-height: 54rpx;
  text-align: center;
  color: #ffffff;
  font-size: 48rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
}

.preview-tips {
  position: absolute;
  bottom: 60rpx;
  left: 50%;
  transform: translateX(-50%);
  color: rgba(255, 255, 255, 0.7);
  font-size: 24rpx;
}
