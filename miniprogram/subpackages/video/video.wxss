.video-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background-color: #000;
  padding: 20rpx;
}

.video-player {
  width: 100%;
  height: 422rpx;
}

.no-video {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 422rpx;
}

.no-video-text {
  color: rgba(255,255,255,0.4);
  font-size: 28rpx;
}

.video-tips {
  margin-top: 30rpx;
  color: rgba(255, 255, 255, 0.6);
  font-size: 24rpx;
  text-align: center;
}
