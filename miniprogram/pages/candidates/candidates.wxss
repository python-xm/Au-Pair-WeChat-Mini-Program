/* pages/candidates/candidates.wxss */

.page-container {
  min-height: 100vh;
  background-color: #f5f6f8;
  display: flex;
  flex-direction: column;
}

.count-bar {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 24rpx 30rpx;
  text-align: center;
}

.count-text {
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
}

.search-bar-small {
  margin: 24rpx 24rpx;
  padding: 14rpx 24rpx;
  background: #fff;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.search-bar-small .search-input {
  flex: 1;
  font-size: 26rpx;
  color: #333;
}

.search-clear {
  width: 36rpx;
  height: 36rpx;
  line-height: 34rpx;
  text-align: center;
  font-size: 28rpx;
  color: #999;
  border-radius: 50%;
  background: #eee;
  flex-shrink: 0;
}

.loading-container,
.empty-container {
  padding: 120rpx 40rpx;
  text-align: center;
}

.loading-text {
  color: #999;
  font-size: 28rpx;
}

.empty-emoji {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  display: block;
  font-size: 30rpx;
  color: #888;
  margin-bottom: 12rpx;
}

.empty-desc {
  display: block;
  font-size: 26rpx;
  color: #bbb;
}

.candidate-scroll {
  flex: 1;
  height: calc(100vh - 300rpx);
  padding: 0 24rpx;
}

.candidate-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding-bottom: 30rpx;
}

.candidate-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
  transition: transform 0.15s;
}

.card-hover {
  transform: scale(0.98);
  box-shadow: 0 6rpx 20rpx rgba(102,126,234,0.12);
}

.card-header {
  display: flex;
  align-items: center;
  padding: 26rpx 24rpx;
}

.avatar-wrapper {
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  flex-shrink: 0;
  background: linear-gradient(135deg, #667eea, #764ba2);
}

.avatar-text {
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
}

.basic-info {
  flex: 1;
  margin-left: 20rpx;
  overflow: hidden;
}

.name-row {
  margin-bottom: 8rpx;
}

.candidate-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
}

.info-row {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

.info-tag {
  font-size: 22rpx;
  color: #666;
  background: #f0f2f5;
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
}

.video-badge {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea, #764ba2);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.video-badge-icon {
  color: #fff;
  font-size: 22rpx;
  margin-left: 4rpx;
}

.card-body {
  padding: 0 24rpx 20rpx;
}

.intro-text {
  font-size: 25rpx;
  color: #777;
  line-height: 1.55;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 10rpx;
}

.tag-row {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

.mini-tag {
  font-size: 21rpx;
  color: #667eea;
  background: rgba(102,126,234,0.08);
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
}

.load-status {
  text-align: center;
  padding: 28rpx 0;
}

.status-text {
  color: #667eea;
  font-size: 26rpx;
}

.no-more-text {
  color: #ccc;
  font-size: 24rpx;
}
