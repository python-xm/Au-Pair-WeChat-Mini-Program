/* pages/index/index.wxss */

.page-container {
  min-height: 100vh;
  background-color: #f5f6f8;
}

/* ====== 顶部标题 ====== */
.header {
  padding: 30rpx 30rpx 20rpx;
  text-align: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.header-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  letter-spacing: 8rpx;
}

.header-subtitle {
  display: block;
  font-size: 22rpx;
  color: rgba(255,255,255,0.75);
  margin-top: 6rpx;
  letter-spacing: 2rpx;
}

/* ====== 搜索栏 ====== */
.search-bar {
  margin: -20rpx 24rpx 30rpx;
  padding: 16rpx 28rpx;
  background: #fff;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
  position: relative;
  z-index: 10;
}

.search-placeholder-icon {
  font-size: 30rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  margin-left: 16rpx;
  color: #333;
}

.search-clear {
  width: 40rpx;
  height: 40rpx;
  line-height: 38rpx;
  text-align: center;
  font-size: 32rpx;
  color: #999;
  border-radius: 50%;
  background: #eee;
  flex-shrink: 0;
}

/* ====== 轮播图 ====== */
.banner-swiper {
  height: 320rpx;
  margin: 0 24rpx 24rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
}

.banner-image {
  width: 100%;
  height: 100%;
  border-radius: 20rpx;
}

/* ====== 功能按钮区 ====== */
.function-grid {
  display: flex;
  justify-content: space-around;
  padding: 30rpx 10rpx;
  background: #fff;
  margin: 0 24rpx;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.func-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx;
}

.func-btn-hover {
  opacity: 0.7;
  transform: scale(0.96);
}

.func-icon {
  width: 140rpx;
  height: 140rpx;
  border-radius: 20rpx;
}

.func-text {
  font-size: 26rpx;
  color: #333;
  margin-top: 14rpx;
  font-weight: 500;
}

/* ====== 分割线 ====== */
.section-divider {
  height: 20rpx;
  background: #f5f6f8;
  margin-top: 20rpx;
}

/* ====== 互惠人选区域 ====== */
.candidates-section {
  padding: 0 24rpx 40rpx;
}

.section-title {
  font-size: 38rpx;
  font-weight: bold;
  color: #333;
  padding: 30rpx 4rpx 24rpx;
  position: relative;
}

.section-title::after {
  content: '';
  position: absolute;
  bottom: 18rpx;
  left: 4rpx;
  width: 56rpx;
  height: 6rpx;
  background: linear-gradient(90deg, #667eea, #764ba2);
  border-radius: 3rpx;
}

/* ====== 加载/空状态 ====== */
.loading-container,
.empty-container {
  padding: 80rpx 0;
  text-align: center;
}

.loading-text,
.empty-text {
  color: #999;
  font-size: 28rpx;
}

/* ====== 人选卡片 ====== */
.candidate-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.candidate-card {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.06);
  transition: transform 0.2s;
}

.card-hover {
  transform: scale(0.98);
  box-shadow: 0 6rpx 24rpx rgba(102,126,234,0.15);
}

.card-header {
  display: flex;
  padding: 28rpx 28rpx 20rpx;
  align-items: center;
}

.avatar-wrapper {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  flex-shrink: 0;
  background: linear-gradient(135deg, #667eea, #764ba2);
}

.avatar-image {
  width: 100%;
  height: 100%;
}

.avatar-text {
  color: #fff;
  font-size: 40rpx;
  font-weight: bold;
}

.basic-info {
  flex: 1;
  margin-left: 24rpx;
  overflow: hidden;
}

.name-row {
  display: flex;
  align-items: baseline;
  margin-bottom: 8rpx;
}

.candidate-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-right: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.age-text {
  font-size: 26rpx;
  color: #888;
  flex-shrink: 0;
}

.info-row {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.info-tag {
  font-size: 22rpx;
  color: #666;
  background: #f0f2f5;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.duration-tag {
  font-weight: 500;
  font-size: 24rpx;
}

.renewable-tag {
  font-size: 20rpx;
  background: #fff3e0 !important;
  color: #e65100 !important;
  border-radius: 10rpx !important;
}

.card-body {
  padding: 0 28rpx 16rpx;
}

.intro-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 28rpx 24rpx;
}

.tag {
  font-size: 22rpx;
  color: #667eea;
  background: rgba(102,126,234,0.1);
  padding: 6rpx 18rpx;
  border-radius: 8rpx;
  max-width: 360rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status-tag {
  font-size: 22rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.status-tag.unmatched {
  color: #ff9500;
  background: rgba(255,149,0,0.1);
}

.status-tag.matched {
  color: #34c759;
  background: rgba(52,199,89,0.1);
}

.video-badge {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea, #764ba2);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.video-badge-icon {
  color: #fff;
  font-size: 24rpx;
  margin-left: 4rpx;
}

.edu-tag {
  color: #764ba2;
  background: rgba(118,75,162,0.1);
}

/* ====== 加载更多 / 到底了 ====== */
.load-more {
  text-align: center;
  padding: 30rpx 0;
}

.load-more-text {
  color: #667eea;
  font-size: 26rpx;
}

.no-more {
  text-align: center;
  padding: 30rpx 0;
}

.no-more-text {
  color: #ccc;
  font-size: 24rpx;
}
