/* pages/detail/detail.wxss */

.page-container {
  min-height: 100vh;
  background-color: #f5f6f8;
}

.page-loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 80vh;
}

.loading-text {
  color: #999;
  font-size: 28rpx;
}

/* ====== 头部区域 ====== */
.header-section {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 50rpx 30rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-large-wrapper {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  border: 6rpx solid rgba(255,255,255,0.3);
  margin-bottom: 24rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
}

.avatar-large-text {
  color: #fff;
  font-size: 64rpx;
  font-weight: bold;
}

.name-section {
  text-align: center;
}

.candidate-name {
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
  display: block;
  margin-bottom: 12rpx;
}

.meta-row {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.meta-item {
  color: rgba(255,255,255,0.9);
  font-size: 26rpx;
}

.meta-dot {
  color: rgba(255,255,255,0.5);
  font-size: 26rpx;
}

/* ====== 视频预览区域 ====== */
.video-section {
  margin: 24rpx;
  border-radius: 20rpx;
  overflow: hidden;
  background: #000;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
}

.video-cover {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  background: linear-gradient(135deg, rgba(102,126,234,0.8), rgba(118,75,162,0.8));
}

.play-btn {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.play-icon {
  font-size: 40rpx;
  color: #667eea;
  margin-left: 6rpx;
}

.video-tip {
  color: rgba(255,255,255,0.8);
  font-size: 26rpx;
}

/* ====== 视频弹窗 ====== */
.video-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.video-modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.7);
}

.video-modal-content {
  position: relative;
  width: 90%;
  background: #000;
  border-radius: 20rpx;
  overflow: hidden;
  z-index: 1;
}

.video-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: rgba(0,0,0,0.5);
}

.video-modal-title {
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
}

.video-modal-close {
  color: #fff;
  font-size: 36rpx;
  padding: 0 10rpx;
}

.detail-video-player {
  width: 100%;
  height: 500rpx;
}

/* ====== 信息卡片区域 ====== */
.info-cards {
  padding: 0 24rpx;
  margin-top: 10rpx;
}

.info-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 28rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.title-icon {
  font-size: 36rpx;
}

/* ====== 信息网格 ====== */
.info-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.info-item {
  width: calc(50% - 10rpx);
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-item.full-width {
  width: 100%;
}

.info-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.info-value {
  display: block;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  word-break: break-all;
}

.info-value.highlight {
  color: #667eea;
  font-weight: bold;
}

/* ====== 信息块 ====== */
.info-block {
  margin-bottom: 20rpx;
}

.info-block:last-child {
  margin-bottom: 0;
}

.block-label {
  display: block;
  font-size: 26rpx;
  color: #888;
  margin-bottom: 14rpx;
}

.block-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.7;
}

.intro-full-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
  display: block;
}

.empty-hint {
  color: #ccc;
  font-style: italic;
}

/* ====== 悬浮分享按钮 ====== */
.share-btn-wrap {
  position: fixed;
  right: 36rpx;
  bottom: 120rpx;
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 28rpx rgba(102,126,234,0.4);
  z-index: 999;
  box-sizing: border-box;
}

.share-icon {
  font-size: 44rpx;
  color: #fff;
  font-weight: bold;
  line-height: 1;
}

.share-text {
  font-size: 20rpx;
  color: rgba(255,255,255,0.9);
  font-weight: 500;
  margin-top: 2rpx;
}

.share-btn-hidden {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0;
  z-index: 10;
  margin: 0;
  padding: 0;
  border: none;
  background: transparent;
}

.share-btn-hidden::after {
  display: none !important;
}
