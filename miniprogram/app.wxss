/* 全局样式 */
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #333;
}

/* 容器通用样式 */
.container {
  padding: 20rpx;
}

/* 标题加粗 */
.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  padding: 30rpx 20rpx 20rpx;
}
